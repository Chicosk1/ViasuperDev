# ─────────────────────────────────────────────────────────────
# Renomear para .env e preencher com seus dados reais.
# ─────────────────────────────────────────────────────────────

# ── Jira ──────────────────────────────────────────────────────
# URL base da sua instância Jira
JIRA_BASE_URL=https://nimitz.atlassian.net

# Email da conta Atlassian
JIRA_EMAIL=seu.email@empresa.com

# Token de API — gerar em:
# https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=seu_token_aqui

# ── Vault ─────────────────────────────────────────────────────
# Caminho absoluto da raiz do vault no seu sistema.
VAULT_ROOT=C:/Users/SEU_USUARIO/VIASUPERDEV

# ── Logging ───────────────────────────────────────────────────
# Nível de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
