{
  "info": {
    "_postman_id": "f7a8b9c0-d1e2-3456-fabc-789012345678",
    "name": "Site Mercado",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "38872675",
    "description": "API de e-commerce Site Mercado. Autenticação OAuth2 via client_id/client_secret. Preencher `base_url_sitemercado`, `sitemercado_client_id` e `sitemercado_client_secret` no ambiente."
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST Autenticar",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"client_id\": \"{{sitemercado_client_id}}\",\n  \"client_secret\": \"{{sitemercado_client_secret}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url_sitemercado}}/api/v1/oauth/token",
              "host": [
                "{{base_url_sitemercado}}"
              ],
              "path": [
                "api",
                "v1",
                "oauth",
                "token"
              ]
            },
            "description": "Autentica na API Site Mercado. Token salvo automaticamente em `token`."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "var token = json.access_token || json.accessToken;",
                  "if (token) {",
                  "    pm.environment.set('token', token);",
                  "    var exp = json.expires_in || 3600;",
                  "    pm.environment.set('token_sitemercado_expires_at', Date.now() + exp * 1000);",
                  "    console.log('Token Site Mercado salvo.');",
                  "}",
                  "pm.test('Token Site Mercado retornado', function() {",
                  "    pm.expect(token, 'token ausente na resposta').to.not.be.undefined;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Pedidos",
      "item": [
        {
          "name": "GET Buscar Pedido",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url_sitemercado}}/api/v1/pedido/:idPedido",
              "host": [
                "{{base_url_sitemercado}}"
              ],
              "path": [
                "api",
                "v1",
                "pedido",
                ":idPedido"
              ],
              "variable": [
                {
                  "key": "idPedido",
                  "value": ""
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "GET Listar Eventos de Pedidos",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url_sitemercado}}/api/v1/pedido/eventos",
              "host": [
                "{{base_url_sitemercado}}"
              ],
              "path": [
                "api",
                "v1",
                "pedido",
                "eventos"
              ]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url_sitemercado",
      "value": "https://service.sitemercado.com.br"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Status code 2xx', function() {",
          "    pm.response.to.be.success;",
          "});",
          "",
          "pm.test('Tempo de resposta < 3s', function() {",
          "    pm.expect(pm.response.responseTime).to.be.below(3000);",
          "});",
          "",
          "var ct = pm.response.headers.get('Content-Type');",
          "if (ct && ct.includes('application/json')) {",
          "    pm.test('JSON válido', function() { pm.response.to.be.json; });",
          "}"
        ]
      }
    }
  ]
}