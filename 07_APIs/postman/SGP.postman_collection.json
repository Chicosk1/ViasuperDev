    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "38872675",
    "description": "API governamental SGP da Prefeitura de Curitiba para execução financeira (vendas, empenhos, autorizações). Autenticação Bearer com refresh automático. Preencher `base_url_sgp`, `sgp_username` e `sgp_password` no ambiente."
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST Autenticar",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"{{sgp_username}}\",\n  \"senha\": \"{{sgp_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url_sgp}}/sgp-api/api/rest/seguranca/auth/token",
              "host": [
                "{{base_url_sgp}}"
              ],
              "path": [
                "sgp-api",
                "api",
                "rest",
                "seguranca",
                "auth",
                "token"
              ]
            },
            "description": "Autentica na API SGP. Token salvo automaticamente em `token`."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "var token = json.token || json.access_token || json.accessToken;",
                  "if (token) {",
                  "    pm.environment.set('token', token);",
                  "    pm.environment.set('token_sgp_expires_at', Date.now() + 3600000);",
                  "    console.log('Token SGP salvo.');",
                  "} else {",
                  "    console.warn('Token SGP não encontrado. Resposta:', JSON.stringify(json));",
                  "}",
                  "pm.test('Token SGP retornado', function() {",
                  "    pm.expect(token, 'token ausente na resposta').to.not.be.undefined;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
