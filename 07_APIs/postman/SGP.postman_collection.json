  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "var token    = pm.environment.get('token');",
          "var expiry   = pm.environment.get('token_sgp_expires_at');",
          "var expired  = !token || (expiry && Date.now() >= Number(expiry) - 30000);",
          "",
          "if (expired) {",
          "    var base = pm.environment.get('base_url_sgp');",
          "    var user = pm.environment.get('sgp_username');",
          "    var pwd  = pm.environment.get('sgp_password');",
          "    if (!base || !user || !pwd) return;",
          "",
          "    pm.sendRequest({",
          "        url: base + '/sgp-api/api/rest/seguranca/auth/token',",
          "        method: 'POST',",
          "        header: { 'Content-Type': 'application/json' },",
          "        body: { mode: 'raw', raw: JSON.stringify({ login: user, senha: pwd }) }",
          "    }, function(err, res) {",
          "        if (err) { console.error('Erro refresh SGP:', err); return; }",
          "        var j = res.json();",
          "        var t = j.token || j.access_token;",
          "        if (t) {",
          "            pm.environment.set('token', t);",
          "            pm.environment.set('token_sgp_expires_at', Date.now() + 3600000);",
          "            console.log('Token SGP renovado automaticamente.');",
          "        }",
          "    });",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Status code 2xx', function() {",
          "    pm.response.to.be.success;",
          "});",
          "",
          "pm.test('Tempo de resposta < 3s', function() {",
          "    pm.expect(pm.response.responseTime).to.be.below(3000);",
          "});",
          "",
          "var ct = pm.response.headers.get('Content-Type');",
          "if (ct && ct.includes('application/json')) {",
          "    pm.test('JSON válido', function() { pm.response.to.be.json; });",
          "}"
        ]
      }
    }
  ]
