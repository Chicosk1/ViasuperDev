  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST Autenticar (Login Web)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"{{apache_user}}\",\n  \"password\": \"{{apache_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url_apache}}/datasnap/rest/TServerFuncoes/UpdateLoginWeb",
              "host": [
                "{{base_url_apache}}"
              ],
              "path": [
                "datasnap",
                "rest",
                "TServerFuncoes",
                "UpdateLoginWeb"
              ]
            },
            "description": "Realiza login na API DataSnap. Salva o authToken automaticamente no ambiente."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// DataSnap retorna { result: ['TOKEN'] } ou { result: [true, 'TOKEN'] }",
                  "var json = pm.response.json();",
                  "var result = json.result;",
                  "var token = Array.isArray(result)",
                  "    ? result.find(function(r) { return typeof r === 'string'; })",
                  "    : (json.authToken || json.token || json.value);",
                  "if (token) {",
                  "    pm.environment.set('authToken', token);",
                  "    console.log('authToken Apache salvo.');",
                  "} else {",
                  "    console.warn('authToken não encontrado. Resposta:', JSON.stringify(json));",
                  "}",
                  "pm.test('Token retornado', function() {",
                  "    pm.expect(token, 'token ausente na resposta').to.not.be.undefined;",
                  "});"
                ]
              }
            }
          ]
        },
